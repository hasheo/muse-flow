# Database
DATABASE_URL="postgresql://user:password@localhost:5432/museflow?sslmode=prefer"

# NextAuth.js
# IMPORTANT: Generate a strong secret for production:
#   openssl rand -base64 32
# Never use the default value in production.
NEXTAUTH_SECRET="change-me-in-production"

# Set to your production domain (e.g. https://museflow.example.com)
# Required for NextAuth.js to work correctly in production.
# On Vercel, set this to your production URL (VERCEL_URL is not sufficient).
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# YouTube Data API v3
# Get a key at https://console.cloud.google.com/apis/credentials
# For production: restrict by HTTP referrer and set quota alerts.
YOUTUBE_API_KEY="your-youtube-data-api-v3-key"

# Upstash Redis (optional — falls back to in-memory rate limiting)
UPSTASH_REDIS_REST_URL="https://<your-upstash-endpoint>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Admin emails (optional — comma-separated list of emails that should be
# promoted to admin on sign-in). Admins get access to /admin/catalog and
# bulk import tooling. Leave empty in environments with no admins.
#   Example: ADMIN_EMAILS="you@example.com,other@example.com"
ADMIN_EMAILS=""

# Survival session token HMAC secret (optional — falls back to
# NEXTAUTH_SECRET). Rotating this invalidates any in-flight survival runs.
#   Generate with: openssl rand -base64 32
QUIZ_SESSION_SECRET=""

# Discogs API token (optional — enables the secondary metadata source used
# by the admin catalog auto-enrichment flow alongside MusicBrainz).
# Without it, MusicBrainz alone still works with lower confidence.
#   Get one at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=""
