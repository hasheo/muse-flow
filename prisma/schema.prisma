generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  playlists     Playlist[]
  quizAttempts  QuizAttempt[]
}

model Playlist {
  id        String          @id @default(cuid())
  name      String
  cover     String          @default("https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&w=900&q=80") @db.Text
  isQuiz    Boolean         @default(false)
  isPublic  Boolean         @default(false)
  difficulty String         @default("normal")
  answerMode String         @default("typed")
  userId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks    PlaylistTrack[]
  quizAttempts QuizAttempt[]
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  playlistId     String
  score          Int
  totalQuestions Int
  difficulty     String
  answerMode     String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist       Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, createdAt])
  @@index([userId, createdAt])
}

model PlaylistTrack {
  id             String   @id @default(cuid())
  playlistId     String
  trackId        String
  position       Int      @default(0)
  sourceType     String
  title          String
  artist         String
  album          String
  duration       Int
  cover          String   @db.Text
  youtubeVideoId String?
  mimeType       String?
  sourcePath     String?  @db.Text
  createdAt      DateTime @default(now())
  playlist       Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
